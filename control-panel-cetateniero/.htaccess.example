# Protecție acces admin
AuthType Basic
AuthName "Zona Restricționată - Acces Interzis"
# IMPORTANT: După clonare pe server, actualizează calea absolută către .htpasswd
# AuthUserFile /path/to/your/project/control-panel-cetateniero/.htpasswd
Require valid-user

# Dezactivare listare directoare
Options -Indexes

# Protecție extra împotriva scanărilor
<IfModule mod_rewrite.c>
RewriteEngine On
# Blocare user-agents suspicioși
RewriteCond %{HTTP_USER_AGENT} (havij|libwww-perl|wget|python|nikto|curl|scan|java|winhttp|clshttp|loader) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (%0A|%0D|%27|%3C|%3E|%00) [NC,OR]
RewriteCond %{HTTP_USER_AGENT} (;|<|>|'|"|\)|\(|%0A|%0D|%22|%27|%28|%3C|%3E|%00).*(libwww-perl|wget|python|nikto|curl|scan|java|winhttp|HTTrack|clshttp|archiver|loader|email|harvest|extract|grab|miner) [NC]
RewriteRule .* - [F,L]
</IfModule>
